# Database - percorso del file SQLite (obbligatorio)
DATABASE_URL="file:./prisma/data.db"

# Anthropic API Key - per generare commenti AI e report PDF (opzionale)
# Senza questa chiave, i commenti saranno generati come placeholder
ANTHROPIC_API_KEY="your-api-key-here"

# Porta su cui gira l'app (default: 3000)
PORT=3000
